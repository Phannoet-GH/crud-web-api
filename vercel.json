{
  "version": 3,
  "functions": {
    "public/**/*.php": {
      "runtime": "vercel-php@0.5.0"
    }
  },
  "rewrites": [
    {
      "source": "/(.*\\.(?:css|js|png|jpg|jpeg|gif|svg|ico|webp|json))",
      "destination": "/public/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/public/index.php"
    }
  ]
}
